{
  "name": "@stoneforge/i18n",
  "version": "1.24.0",
  "type": "module",
  "description": "Shared i18n infrastructure, French locales, and translation utilities for Stoneforge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./locales/fr/common": {
      "types": "./locales/fr/common.json",
      "bun": "./locales/fr/common.json",
      "import": "./dist/locales/fr/common.json",
      "default": "./dist/locales/fr/common.json"
    },
    "./locales/fr/ui": {
      "types": "./locales/fr/ui.json",
      "bun": "./locales/fr/ui.json",
      "import": "./dist/locales/fr/ui.json",
      "default": "./dist/locales/fr/ui.json"
    }
  },
  "files": [
    "dist",
    "locales"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test src",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "i18next": "^24.2.2",
    "react-i18next": "^15.4.1"
  },
  "peerDependencies": {
    "i18next": "^24.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-i18next": "^15.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "license": "Apache-2.0"
}
